{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll": "explicit"
  },
  "dart.lineLength": 80,
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.rulers": [
      80
    ],
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll": "explicit"
    }
  },
  // ═══════════════════════════════════════════════════════════
  // Indent Guides - خطوط المسافات البادئة المحسّنة
  // ═══════════════════════════════════════════════════════════
  "editor.guides.indentation": true,
  "editor.guides.bracketPairs": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.bracketPairColorization.enabled": true,
  // ═══════════════════════════════════════════════════════════
  // تخصيص الألوان - Colors Customization
  // ═══════════════════════════════════════════════════════════
  "workbench.colorCustomizations": {
    // خطوط المسافات البادئة العادية
    "editorIndentGuide.background": "#404040",
    // خط المسافة البادئة النشط (الذي يحتوي على المؤشر)
    "editorIndentGuide.activeBackground": "#707070",
    // ألوان الأقواس المتطابقة (Bracket Pair Colorization)
    "editorBracketHighlight.foreground1": "#FFD700",
    "editorBracketHighlight.foreground2": "#DA70D6",
    "editorBracketHighlight.foreground3": "#87CEEB",
    "editorBracketHighlight.foreground4": "#98FB98",
    "editorBracketHighlight.foreground5": "#FFA07A",
    "editorBracketHighlight.foreground6": "#DDA0DD",
    // تمييز الأقواس غير المتطابقة
    "editorBracketHighlight.unexpectedBracket.foreground": "#FF0000"
  },
  // ═══════════════════════════════════════════════════════════
  // إعدادات إضافية لتحسين تجربة Flutter/Dart
  // ═══════════════════════════════════════════════════════════
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.fontLigatures": true,
  "kiroAgent.configureMCP": "Disabled",
  "chat.mcp.assisted.nuget.enabled": false
}