# Copyright © 2025 Apex Flow Group. All rights reserved.

# ═══════════════════════════════════════════════════════════════════════════
# 🎯 Import Order Rules
# ═══════════════════════════════════════════════════════════════════════════

# Standard import order (following Dart style guide):
# 1. Dart core libraries (dart:*)
# 2. Flutter framework (package:flutter/*)
# 3. External packages (package:*)
# 4. Project imports (package:apex_note/*)
# 5. Relative imports (../ or ./)
# 6. Part directives (part '*.dart')
# 7. Export directives (export '*.dart')

# ═══════════════════════════════════════════════════════════════════════════
# 📁 Excluded Patterns
# ═══════════════════════════════════════════════════════════════════════════

excluded_files:
  - "*.g.dart"           # Generated files
  - "*.freezed.dart"     # Freezed generated files
  - "*.mocks.dart"       # Mock files
  - "generated/**"       # Generated directory
  - ".dart_tool/**"      # Dart tool cache

# ═══════════════════════════════════════════════════════════════════════════
# ⚙️ Fixer Options
# ═══════════════════════════════════════════════════════════════════════════

options:
  remove_duplicates: true        # Remove duplicate imports
  sort_alphabetically: true      # Sort imports alphabetically within groups
  add_blank_lines: true          # Add blank lines between groups
  preserve_comments: true        # Keep comments above imports
  fix_relative_paths: true       # Convert absolute to relative where appropriate
  
# ═══════════════════════════════════════════════════════════════════════════
# 🔍 Analysis Rules
# ═══════════════════════════════════════════════════════════════════════════

analysis:
  warn_on_duplicates: true       # Warn about duplicate imports
  warn_on_unused: false          # Warn about unused imports (requires analysis)
  max_imports_per_file: 50       # Warn if file has too many imports
  
# ═══════════════════════════════════════════════════════════════════════════
# 📦 Package Grouping
# ═══════════════════════════════════════════════════════════════════════════

# Special handling for specific packages
package_groups:
  flutter:
    - "package:flutter/"
    - "package:flutter_test/"
  
  project:
    - "package:apex_note/"
  
  external:
    - "package:provider/"
    - "package:isar/"
    - "package:path_provider/"
    - "package:shared_preferences/"

# ═══════════════════════════════════════════════════════════════════════════
# 🎨 Formatting
# ═══════════════════════════════════════════════════════════════════════════

formatting:
  use_single_quotes: true        # Prefer single quotes
  trailing_comma: false          # No trailing comma in imports
  line_length: 80                # Max line length (for wrapping)

# ═══════════════════════════════════════════════════════════════════════════
# 📝 Examples
# ═══════════════════════════════════════════════════════════════════════════

# ✅ CORRECT:
# import 'dart:async';
# import 'dart:io';
#
# import 'package:flutter/material.dart';
#
# import 'package:provider/provider.dart';
#
# import 'package:apex_note/models/note.dart';
#
# import '../services/database_service.dart';
# import 'note_editor.dart';

# ❌ INCORRECT:
# import 'note_editor.dart';
# import 'package:flutter/material.dart';
# import 'dart:async';
# import '../services/database_service.dart';
